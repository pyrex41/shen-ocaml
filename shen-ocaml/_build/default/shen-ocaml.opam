opam-version: "2.0"
synopsis: "Shen Language port to OCaml"
description: "A performant port of Shen to OCaml 5."
depends: [
  "ocaml" {>= "5.3.0"}
  "dune" {>= "3.20" & >= "3.20"}
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]
x-maintenance-intent: ["(latest)"]
